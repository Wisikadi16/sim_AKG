    // Handle checkbox arrays
    const handleCheckboxArray = (e, fieldName) => {
        const { value, checked } = e.target;
        let currentArray = [...formData[fieldName]];

        if (checked) {
            currentArray.push(value);
        } else {
            currentArray = currentArray.filter(item => item !== value);
        }

        setFormData(fieldName, currentArray);
    };
    // Fungsi utama untuk submit
    const handleSubmit = (e) => {
        e.preventDefault();
