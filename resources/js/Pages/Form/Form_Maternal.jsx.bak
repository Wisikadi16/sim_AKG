            if (jam.length == 1) {
                jam = "0" + jam;
            }
            var menit = JSON.stringify(e.$m);
            if (menit.length == 1) {
                menit = "0" + menit;
            }

            set_identitas_bayi({
                ...identitas_bayi,
                ["jam_lahir"]: jam + ":" + menit,
            });
        }
        else {
            const value = e.target.value;
            set_identitas_bayi({
                ...identitas_bayi,
                [e.target.name]: value,
            });
        }

